# Billing server env vars — copy to .env for local development.
# Real values live in the Railway dashboard for production.
# These are server-side only and never sent to the browser.

# Stripe
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# Supabase (service role bypasses RLS — server-only)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ-your-service-role-key

# Email (Resend)
RESEND_API_KEY=re_your-resend-key
FROM_EMAIL=MatchedCare <notifications@matchedcare.us>

# SMS (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+18556437685

# Internal cron / ops endpoints (must be set for /start-billing,
# /check-billing to be callable over HTTP). Generate with:
#   openssl rand -hex 32
CRON_SECRET=generate-a-random-64-char-hex-string

# Server
PORT=3001
